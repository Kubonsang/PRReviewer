#!/usr/bin/env bash
set -euo pipefail

_PRR_SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$_PRR_SCRIPT" ]]; do
  _PRR_SCRIPT="$(readlink "$_PRR_SCRIPT")"
done
PRR_DIR="$(cd "$(dirname "$_PRR_SCRIPT")" && pwd)"
unset _PRR_SCRIPT
export PRR_DIR

COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in

  # ── 스킬 동기화 ────────────────────────────────────────────
  skill)
    SUBCOMMAND="${1:-}"
    CLAUDE_SKILLS_DIR="${HOME}/.claude/skills"
    case "$SUBCOMMAND" in
      sync)
        echo "스킬 동기화: $PRR_DIR/skills/ → $CLAUDE_SKILLS_DIR/"
        echo ""
        mkdir -p "$CLAUDE_SKILLS_DIR"
        synced=0
        for skill_dir in "$PRR_DIR/skills"/*/; do
          cp -r "$skill_dir" "$CLAUDE_SKILLS_DIR/"
          echo "  ✓ $(basename "$skill_dir")"
          synced=$((synced + 1))
        done
        echo ""; echo "${synced}개 스킬 동기화 완료."
        ;;
      status)
        echo "=== PRR 스킬 상태 ==="; echo ""
        for skill_dir in "$PRR_DIR/skills"/*/; do
          skill_name="$(basename "$skill_dir")"
          src="$skill_dir/SKILL.md"
          dst="$CLAUDE_SKILLS_DIR/$skill_name/SKILL.md"
          printf "  %-24s " "$skill_name"
          if   [[ ! -f "$dst" ]];                       then echo "✗ 미설치  → prr skill sync"
          elif diff -q "$src" "$dst" &>/dev/null;        then echo "✓ 최신"
          else                                                echo "! 변경됨  → prr skill sync"
          fi
        done
        echo ""
        ;;
      *) echo "사용법: prr skill <sync|status>" ;;
    esac
    ;;

  # ── 환경 상태 확인 ─────────────────────────────────────────
  status)
    echo "=== PRR 환경 상태 ==="; echo ""
    printf "gh CLI:      "
    if command -v gh &>/dev/null; then
      if gh auth status &>/dev/null 2>&1; then
        GH_USER=$(gh api user --jq '.login' 2>/dev/null || echo "알 수 없음")
        echo "✓ 인증됨 (@$GH_USER)"
      else
        echo "✗ 미인증  → gh auth login"
      fi
    else
      echo "✗ 설치되지 않음  → brew install gh"
    fi
    printf "Python 3:    "
    if command -v python3 &>/dev/null; then
      echo "✓ $(python3 --version 2>&1 | awk '{print $2}')"
    else
      echo "✗ 설치되지 않음"
    fi
    echo ""
    REPO_COUNT=$(find "$PRR_DIR/configs/repos" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
    echo "등록된 리포: ${REPO_COUNT}개"
    echo "PRR 경로:    $PRR_DIR"
    ;;

  # ── 도움말 ─────────────────────────────────────────────────
  help|--help|-h)
    echo "사용법: prr <커맨드> [인수]"
    echo ""
    echo "커맨드:"
    echo "  skill sync           스킬을 ~/.claude/skills/ 에 동기화"
    echo "  skill status         스킬 동기화 상태 확인"
    echo "  status               환경 상태 확인 (gh, python3)"
    echo ""
    echo "스킬 (AI 코딩 툴에서 실행):"
    echo "  /prr-scan <path> <owner/repo>          리포 등록 + env.json 생성"
    echo "  /prr-add-reviewer <owner/repo>         리뷰어 추천 및 설정"
    echo "  /prr-review <owner/repo> <pr-number>   PR 리뷰 실행"
    echo "  /prr-followup <owner/repo> <pr-number> 수정 여부 확인 후 답글 게시"
    ;;

  *)
    echo "오류: 알 수 없는 커맨드 '$COMMAND'" >&2
    echo "도움말: prr help" >&2
    exit 1
    ;;
esac
